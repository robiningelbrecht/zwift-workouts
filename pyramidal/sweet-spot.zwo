<workout_file>
  <author>ChatGPT</author>
  <name>Sweet Spot 3x15 @ 90%</name>
  <description>
    Sustainable long sweet spot workout.
    Main set: 3x15min @ 90% FTP with 5min recovery.
    Total sweet spot time: 45min.
    Total duration: ~80 minutes.
  </description>
  <sportType>bike</sportType>

  <workout>
    <!-- Warmup 15 min -->
    <Warmup Duration="900" PowerLow="0.50" PowerHigh="0.75"/>

    <!-- Main set: 3x15 min @ 90% -->
    <SteadyState Duration="900" Power="0.90"/>
    <SteadyState Duration="300" Power="0.60"/>

    <SteadyState Duration="900" Power="0.90"/>
    <SteadyState Duration="300" Power="0.60"/>

    <SteadyState Duration="900" Power="0.90"/>
    <SteadyState Duration="300" Power="0.60"/>

    <!-- Cooldown 15 min -->
    <Cooldown Duration="900" PowerLow="0.65" PowerHigh="0.45"/>
  </workout>
</workout_file>